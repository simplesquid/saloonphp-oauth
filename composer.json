{
    "name": "simplesquid/saloonphp-oauth",
    "description": "Concurrent-safe OAuth auto-refresh for Saloon v4 and Laravel",
    "keywords": [
        "simplesquid",
        "laravel",
        "saloon",
        "saloonphp",
        "oauth",
        "auto-refresh"
    ],
    "homepage": "https://github.com/simplesquid/saloonphp-oauth",
    "license": "MIT",
    "authors": [
        {
            "name": "Matthew Poulter",
            "email": "matthew.poulter@simplesquid.co.za",
            "homepage": "https://simplesquid.co.za/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "saloonphp/saloon": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SimpleSquid\\SaloonOAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleSquid\\SaloonOAuth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SimpleSquid\\SaloonOAuth\\SaloonOAuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
